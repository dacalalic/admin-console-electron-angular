{
  "name": "admin-console",
  "version": "0.0.0",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "start": "ng serve",
    "build:electron": "rimraf dist-electron && tsc -p electron/tsconfig.json",
    "start:electron": "npm run build:electron && electron .",
    "start:desktop": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && npm run start:electron\"",
    "rebuild:electron": "electron-rebuild"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  }
}
